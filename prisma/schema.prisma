generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/meu_livro/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image             String?
  passwordHash     String?
  isPremium        Boolean   @default(false)
  premiumExpiresAt DateTime?
  role              String    @default("USER")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  accounts          Account[]
  sessions          Session[]
  books             Book[]
  payments          Payment[]
  communityPosts    CommunityPost[]
  communityLikes    CommunityLike[]
  communityComments CommunityComment[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Book {
  id                 String              @id @default(cuid())
  userId             String
  title              String
  genre              String?
  synopsis           String?             @db.Text
  isPublished        Boolean             @default(false)
  sampleContent      String?             @db.Text
  salesLink          String?
  coverStoragePath       String?
  coverContentType       String?
  coverIsPublic          Boolean             @default(false)
  backCoverStoragePath   String?
  backCoverContentType   String?
  backCoverIsPublic      Boolean             @default(false)
  targetWordCount    Int                 @default(50000)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters           Chapter[]
  characters         Character[]
  worldNotes         WorldNote[]
  structureTimeline  StructureTimeline[]
  @@index([userId, updatedAt])
}

model Chapter {
  id        String   @id @default(cuid())
  bookId    String
  order     Int
  title     String
  content   String   @default("") @db.Text
  wordCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@unique([bookId, order])
  @@index([bookId, updatedAt])
}

model Character {
  id                   String   @id @default(cuid())
  bookId               String
  name                 String
  avatarStoragePath    String?
  avatarContentType    String?
  avatarIsPublic       Boolean  @default(false)
  biography            String?  @db.Text
  archetype             String?
  goal                  String?  @db.Text
  conflict              String?  @db.Text
  details               Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  book                  Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@index([bookId])
}

model WorldNote {
  id        String   @id @default(cuid())
  bookId    String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@index([bookId, updatedAt])
}

model StructureTimeline {
  id          String   @id @default(cuid())
  bookId      String
  act         String
  description String   @db.Text
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  @@unique([bookId, order])
  @@index([bookId])
}

model CommunityPost {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     CommunityLike[]
  comments  CommunityComment[]
  @@index([createdAt(sort: Desc)])
  @@index([userId])
}

model CommunityLike {
  id     String @id @default(cuid())
  userId String
  postId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([userId, postId])
  @@index([postId])
}

model CommunityComment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@index([postId, createdAt])
}

model Payment {
  id                 String   @id @default(cuid())
  userId             String
  externalId         String   @unique
  status             String
  amountCents        Int      @default(1200)
  eventType          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}
